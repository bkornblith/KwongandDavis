{
  "functions": {
    "api/**/*.js": { "maxDuration": 15 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/form",     "dest": "/public/index.html" },
    { "src": "/form/(.*)", "dest": "/public/$1" },
    { "src": "/(.*)",     "dest": "/public/$1" }
  ]
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)",     "destination": "/$1" }
  ]
}
}